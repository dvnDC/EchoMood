<%# app/views/admin/users/index.html.erb %>
<section class="wrapper style1">
  <div class="container">
    <div class="row gtr-200">
      <h1>Zarządzanie użytkownikami</h1>

      <table>
        <thead>
        <tr>
          <th>Email</th>
          <th>Role</th>
          <th>Akcje</th>
        </tr>
        </thead>
        <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.email %></td>
            <td><%= user.roles.pluck(:name).join(", ") %></td>
            <td>
              <%= link_to "Edytuj role", edit_admin_user_path(user) %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>