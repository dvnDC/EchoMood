<%= turbo_stream_from "ai_suggestion_#{current_user.id}" %>

<!-- Main -->
<section class="wrapper style1">
  <div class="container">
    <div class="row gtr-200">
      <div class="col-4 col-12-narrower">
        <div id="sidebar">

          <!-- Sidebar -->

          <section>
            <h3>How are you feeling today?</h3>
            <p>Take a moment to pause. Think about what’s going on in your world today—both inside and out..</p>
            <p>Your mood is an important signal. Write it down and give yourself space to understand.</p>
            <p>✍️ Click “New Entry” when you’re ready.</p>
            <footer>
              <%= link_to "New Entry", new_mood_entry_path, class: "button" %>
            </footer>
          </section>

          <section>
            <h3>Your Recent Mood Entries</h3>
            <% if @recent_mood_entries.any? %>
              <ul class="links">
                <% @recent_mood_entries.each do |entry| %>
                  <li>
                    <%= link_to mood_entry_path(entry) do %>
                      <strong><%= entry.entry_date&.strftime("%b %d") || "No date" %></strong>
                      <% if entry.created_at.present? %>
                        at <%= entry.created_at.strftime("%I:%M %p") %> -
                      <% else %>
                        -
                      <% end %>
                      Mood: <%= entry.mood_level %>
                    <% end %>
                  </li>
                <% end %>
              </ul>
              <p>Tracking your moods over time helps you recognize patterns and understand your emotional health.</p>
            <% else %>
              <p>You haven't added any mood entries yet. Start your mood tracking journey today!</p>
            <% end %>
            <footer>
              <%= link_to "View all entries", all_mood_entries_path, class: "button" %>
            </footer>
          </section>

        </div>
      </div>
      <div class="col-8  col-12-narrower imp-narrower">
        <div id="content">

          <!-- Content -->

          <article>
            <header>
              <h2>Mood Tracking</h2>
              <p>Your mood history.</p>
            </header>

            <%#= turbo_frame_tag "ai_suggestion_frame" do %>
              <%#= render 'shared/ai_suggestion', latest_mood_entry: @latest_mood_entry %>
            <%# end %>

            <h3>Your Mood Calendar</h3>
            <p>Each tile represents a day, colored by your mood level. Hover over a tile to see details.</p>

            <div class="mood-grid" data-controller="mood-grid">


                <% @mood_grid_data.each do |date, entry| %>
                  <% if entry.nil? %>
                    <div class="mood-cell empty" data-date="<%= date.strftime('%Y-%m-%d') %>">
                      <div class="mood-date"><%= date.strftime('%-d') %></div>
                      <div class="mood-weekday"><%= date.strftime('%a') %></div>
                      <span class="mood-tooltip"><%= date.strftime('%b %d, %Y') %> - No entry</span>
                    </div>
                  <% else %>
                  <div class="mood-cell level-<%= entry.mood_level %>" data-date="<%= date.strftime('%Y-%m-%d') %>" data-entry-id="<%= entry.id %>">
                      <div class="mood-date"><%= date.strftime('%-d') %></div>
                      <div class="mood-weekday"><%= date.strftime('%a') %></div>
                      <div class="mood-level"><%= entry.mood_level %></div>
                      <span class="mood-tooltip">
                        <%= date.strftime('%b %d, %Y') %> - Mood: <%= entry.mood_level %>/5
                        <% if entry.note.present? %>
                          <br><small><%= truncate(entry.note, length: 30) %></small>
                        <% end %>
                      </span>
                    </div>
                  <% end %>
                <% end %>
              </div>

            <div class="mood-legend">
              <h4>Mood Legend:</h4>
              <div style="display: flex; gap: 10px; align-items: center;">
                <div style="display: flex; align-items: center;">
                  <div class="mood-cell level-1" style="width: 20px; height: 20px;"></div>
                  <span style="margin-left: 5px;">Very Low (1)</span>
                </div>
                <div style="display: flex; align-items: center;">
                  <div class="mood-cell level-2" style="width: 20px; height: 20px;"></div>
                  <span style="margin-left: 5px;">Low (2)</span>
                </div>
                <div style="display: flex; align-items: center;">
                  <div class="mood-cell level-3" style="width: 20px; height: 20px;"></div>
                  <span style="margin-left: 5px;">Neutral (3)</span>
                </div>
                <div style="display: flex; align-items: center;">
                  <div class="mood-cell level-4" style="width: 20px; height: 20px;"></div>
                  <span style="margin-left: 5px;">Good (4)</span>
                </div>
                <div style="display: flex; align-items: center;">
                  <div class="mood-cell level-5" style="width: 20px; height: 20px;"></div>
                  <span style="margin-left: 5px;">Very Good (5)</span>
                </div>
              </div>
            </div>



              <h3>Mood Trend (Last 14 Days)</h3>

            <div data-controller="chart">
              <canvas
                data-chart-target="canvas"
                data-type="line"
                data-labels='<%= @dates.to_json %>'
                data-datasets='<%= [
                                     {
                                       label: "Mood Level (1-5)",
                                       data: @mood_scores,
                                       borderColor: "#3e95cd",
                                       backgroundColor: "rgba(62, 149, 205, 0.2)",
                                       fill: true,
                                       tension: 0.2
                                     }
                                   ].to_json %>'
                style="width: 100%; height: 300px;"
              ></canvas>
            </div>

            <% if Rails.env.development? %>
              <div style="margin-top: 20px; padding: 10px; background-color: #f5f5f5; border: 1px solid #ddd;">
                <h4>Debug Info:</h4>
                <p>Dates: <%= @dates.inspect %></p>
                <p>Mood Scores: <%= @mood_scores.inspect %></p>
              </div>
            <% end %>

          </article>

        </div>
      </div>
    </div>
  </div>
</section>
