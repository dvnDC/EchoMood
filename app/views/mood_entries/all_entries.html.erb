<section class="wrapper style1">
  <div class="container">
    <div id="content">

      <h1>All Your Mood Entries</h1>

      <div class="actions-bar" style="margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center;">
        <div>
          <%= link_to new_mood_entry_path, class: "button primary" do %>
            <i class="fa fa-plus-circle"></i> New Mood Entry
          <% end %>
          <%= link_to mood_entries_path, class: "button" do %>
            <i class="fa fa-chart-line"></i> Return
          <% end %>
        </div>
        <div class="search-filter" style="position: relative;">
          <input type="text" placeholder="Search entries..." style="padding-left: 35px; width: 250px;">
          <i class="fa fa-search" style="position: absolute; left: 12px; top: 12px; color: #999;"></i>
        </div>
      </div>

      <!-- Dodajemy mapę nastroju na górze -->
      <div class="mood-map-container" style="margin-bottom: 30px;">
        <h3>Your Mood Calendar</h3>
        <p>Each tile represents a day, colored by your mood level.</p>
        <div class="mood-grid" data-controller="mood-grid">
          <% dates = {} %>
          <% (Date.today - 13..Date.today).each do |date| %>
            <% entry = @mood_entries.find { |e| e.entry_date == date } %>
            <% dates[date] = entry %>
          <% end %>

          <% dates.each do |date, entry| %>
            <% if entry.nil? %>
              <div class="mood-cell empty" data-date="<%= date.strftime('%Y-%m-%d') %>">
                <div class="mood-date"><%= date.strftime('%-d') %></div>
                <div class="mood-weekday"><%= date.strftime('%a') %></div>
                <span class="mood-tooltip"><%= date.strftime('%b %d, %Y') %> - No entry</span>
              </div>
            <% else %>
              <div class="mood-cell level-<%= entry.mood_level %>" data-date="<%= date.strftime('%Y-%m-%d') %>" data-entry-id="<%= entry.id %>">
                <div class="mood-date"><%= date.strftime('%-d') %></div>
                <div class="mood-weekday"><%= date.strftime('%a') %></div>
                <div class="mood-level"><%= entry.mood_level %></div>
                <span class="mood-tooltip">
                  <%= date.strftime('%b %d, %Y') %> - Mood: <%= entry.mood_level_description %>
                  <% if entry.note.present? %>
                    <br><small><%= truncate(entry.note, length: 30) %></small>
                  <% end %>
                </span>
              </div>
            <% end %>
          <% end %>
        </div>

        <div class="mood-legend" style="margin-top: 10px;">
          <h4>Mood Legend:</h4>
          <div style="display: flex; flex-wrap: wrap; gap: 10px; align-items: center;">
            <div style="display: flex; align-items: center;">
              <div class="mood-cell level-1" style="width: 20px; height: 20px;"></div>
              <span style="margin-left: 5px;">Very Low (1)</span>
            </div>
            <div style="display: flex; align-items: center;">
              <div class="mood-cell level-2" style="width: 20px; height: 20px;"></div>
              <span style="margin-left: 5px;">Low (2)</span>
            </div>
            <div style="display: flex; align-items: center;">
              <div class="mood-cell level-3" style="width: 20px; height: 20px;"></div>
              <span style="margin-left: 5px;">Neutral (3)</span>
            </div>
            <div style="display: flex; align-items: center;">
              <div class="mood-cell level-4" style="width: 20px; height: 20px;"></div>
              <span style="margin-left: 5px;">Good (4)</span>
            </div>
            <div style="display: flex; align-items: center;">
              <div class="mood-cell level-5" style="width: 20px; height: 20px;"></div>
              <span style="margin-left: 5px;">Very Good (5)</span>
            </div>
          </div>
        </div>
      </div>

      <div class="mood-entries-list">
        <% if @mood_entries.any? %>
          <div class="mood-entries-card-container" style="background: white; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); overflow: hidden;">
            <table style="width: 100%; border-collapse: collapse; margin: 0;">
              <thead>
              <tr style="background: #f8f9fa; border-bottom: 2px solid #eaeaea;">
                <th style="padding: 16px; text-align: left; font-weight: 600; color: #444; font-size: 0.9em;">DATE</th>
                <th style="padding: 16px; text-align: left; font-weight: 600; color: #444; font-size: 0.9em;">TIME</th>
                <th style="padding: 16px; text-align: left; font-weight: 600; color: #444; font-size: 0.9em;">MOOD</th>
                <th style="padding: 16px; text-align: left; font-weight: 600; color: #444; font-size: 0.9em;">NOTES</th>
                <th style="padding: 16px; text-align: center; font-weight: 600; color: #444; font-size: 0.9em; width: 150px;">ACTIONS</th>
              </tr>
              </thead>
              <tbody>
              <% @mood_entries.each_with_index do |entry, index| %>
                <tr style="border-bottom: 1px solid #edf2f7; <%= index.even? ? 'background-color: #fcfcfc;' : '' %>">
                  <td style="padding: 16px; font-weight: 500; color: #333;"><%= entry.entry_date&.strftime("%b %d, %Y") || "No date" %></td>
                  <td style="padding: 16px; color: #555;"><%= entry.created_at.strftime("%I:%M %p") if entry.created_at.present? %></td>
                  <td style="padding: 16px;">
                    <!-- Używamy poprawnych kolorów i nazw z modelu -->
                    <% mood_colors = {
                      1 => "#ff0000", # Very Low - bardzo czerwony
                      2 => "#ff7f7f", # Low - lekko czerwony
                      3 => "#fdffb6", # Neutral - żółty
                      4 => "#91cc0f", # Good - lekko zielony
                      5 => "#089e08"  # Very Good - mocno zielony
                    } %>
                    <div style="display: flex; align-items: center;">
                      <div style="background-color: <%= mood_colors[entry.mood_level] || '#777' %>; width: 10px; height: 10px; border-radius: 50%; margin-right: 8px;"></div>
                      <span style="background-color: <%= mood_colors[entry.mood_level] || '#777' %>20; color: <%= mood_colors[entry.mood_level] == '#fdffb6' ? '#666' : mood_colors[entry.mood_level] || '#777' %>; padding: 4px 12px; border-radius: 20px; font-size: 0.85em; font-weight: 500;">
                        <%= entry.mood_level_description %>
                      </span>
                    </div>
                  </td>
                  <td style="padding: 16px; color: #555;">
                    <% if entry.respond_to?(:note) && entry.note.present? %>
                      <!-- Wyświetlamy całą notatkę, nie przycinamy -->
                      <div class="notes-preview" style="white-space: pre-wrap;"><%= entry.note %></div>
                    <% else %>
                      <span style="color: #999; font-style: italic;">No notes</span>
                    <% end %>
                  </td>
                  <td style="padding: 16px; text-align: center;">
                    <div style="display: flex; justify-content: center; gap: 8px;">
                      <!-- Zmieniony przycisk Edit -->
                      <%= link_to edit_mood_entry_path(entry), class: "small-button edit-btn", style: "width: auto; padding: 6px 12px;" do %>
                        Edit
                      <% end %>

                      <!-- Zmieniony przycisk Delete z potwierdzeniem -->
                      <%= button_to mood_entry_path(entry),
                                    method: :delete,
                                    form: { data: { turbo_confirm: 'Are you sure you want to delete this entry?' } },
                                    class: "small-button delete-btn",
                                    style: "width: auto; padding: 6px 12px; border: none; cursor: pointer;" do %>
                        Delete
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
              </tbody>
            </table>
          </div>

          <div class="pagination" style="margin-top: 30px; display: flex; justify-content: center;">
            <div style="display: flex; gap: 5px; align-items: center;">
              <a href="#" style="padding: 8px 12px; border-radius: 6px; background: #f1f1f1; color: #666; text-decoration: none;">&laquo;</a>
              <a href="#" style="padding: 8px 12px; border-radius: 6px; background: #4e7ac7; color: white; text-decoration: none;">1</a>
              <a href="#" style="padding: 8px 12px; border-radius: 6px; background: #f1f1f1; color: #666; text-decoration: none;">&raquo;</a>
            </div>
          </div>
        <% else %>
          <div class="empty-state" style="text-align: center; padding: 60px 30px; background: white; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
            <div style="width: 80px; height: 80px; background: #f3f4f6; border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
              <i class="fa fa-book" style="font-size: 32px; color: #9ca3af;"></i>
            </div>
            <h3 style="margin-bottom: 10px; font-weight: 600; color: #333;">No Mood Entries Yet</h3>
            <p style="color: #6b7280; margin-bottom: 25px; max-width: 400px; margin-left: auto; margin-right: auto;">Start tracking your mood journey by adding your first entry. It only takes a minute!</p>
            <%= link_to new_mood_entry_path, class: "button primary large", style: "padding: 12px 24px; border-radius: 8px;" do %>
              <i class="fa fa-plus-circle"></i> Add Your First Entry
            <% end %>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</section>