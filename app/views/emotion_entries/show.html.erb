<section class="wrapper style1">
  <div class="container">
    <div id="content">

      <h1>Emotion Entry Details</h1>

      <div class="actions-bar" style="margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center;">
        <div>
          <%= link_to emotion_entries_path, class: "button" do %>
            <i class="fa fa-arrow-left"></i> Back to Emotion Entries
          <% end %>
          <%= link_to edit_emotion_entry_path(@emotion_entry), class: "button primary" do %>
            <i class="fa fa-edit"></i> Edit Entry
          <% end %>
        </div>
        <div>
          <%= button_to emotion_entry_path(@emotion_entry),
                        method: :delete,
                        form: { data: { turbo_confirm: 'Are you sure you want to delete this emotion entry?' } },
                        class: "button delete-btn",
                        style: "border: none; cursor: pointer; background-color: #dc3545;" do %>
            <i class="fa fa-trash"></i> Delete Entry
          <% end %>
        </div>
      </div>

      <div class="emotion-entry-detail" style="background: white; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); overflow: hidden;">

        <!-- Header Section z niebieskim tłem -->
        <div class="entry-header" style="background: linear-gradient(135deg, #4e7ac7 0%, #3a5998 100%); color: white; padding: 30px;">
          <div>
            <h2 style="margin: 0 0 10px 0; font-size: 1.8em; font-weight: 600;">
              <%= @emotion_entry.date.strftime("%B %d, %Y") %>
            </h2>
            <p style="margin: 0 0 15px 0; opacity: 0.9; font-size: 1.1em;">
              <i class="fa fa-clock"></i>
              <%= @emotion_entry.entry_time.strftime("%I:%M %p") %>
            </p>
            <% if @emotion_entry.respond_to?(:predicted_emotion) && @emotion_entry.predicted_emotion.present? %>
              <div style="background: rgba(255,255,255,0.2); padding: 8px 16px; border-radius: 20px; display: inline-block; font-size: 0.95em;">
                <i class="fa fa-heart"></i> <%= @emotion_entry.predicted_emotion %>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Emotion Quadrant Visualization using existing JavaScript -->
        <div class="emotion-visualization" style="padding: 50px 40px; border-bottom: 1px solid #edf2f7;">
          <h3 style="margin-bottom: 40px; color: #333; text-align: center; font-size: 1.4em;">Emotion Positioning</h3>

          <div style="display: flex; gap: 60px; align-items: center; justify-content: center;">
            <!-- Chart.js Canvas with existing controller -->
            <div style="width: 500px; height: 500px; position: relative;">
              <canvas
                data-controller="quadrant-chart"
                data-quadrant-chart-canvas-target="canvas"
                data-points='[{"x": <%= @emotion_entry.valence %>, "y": <%= @emotion_entry.arousal %>, "label": "<%= @emotion_entry.predicted_emotion || 'Current Entry' %>"}]'
                style="width: 100%; height: 100%;">
              </canvas>
            </div>

            <!-- Values Panel -->
            <div style="min-width: 350px;">
              <div class="emotion-values">
                <div style="margin-bottom: 40px;">
                  <h4 style="margin-bottom: 18px; color: #333; font-size: 1.3em;">
                    <i class="fa fa-arrows-alt-h" style="color: #4e7ac7;"></i> Valence
                  </h4>
                  <div style="display: flex; align-items: center; gap: 18px;">
                    <div class="value-bar" style="flex: 1; height: 30px; background: #f1f5f9; border-radius: 15px; position: relative; overflow: hidden; border: 2px solid #e2e8f0;">
                      <% valence_percentage = ((@emotion_entry.valence + 10) / 20.0) * 100 %>
                      <div style="width: <%= valence_percentage %>%; height: 100%; background: linear-gradient(90deg, #ef4444 0%, #fbbf24 50%, #22c55e 100%); border-radius: 15px;"></div>
                    </div>
                    <span style="font-weight: 700; color: #4e7ac7; min-width: 50px; font-size: 1.4em;"><%= @emotion_entry.valence %></span>
                  </div>
                  <div style="display: flex; justify-content: space-between; font-size: 0.9em; color: #666; margin-top: 12px; padding: 0 8px;">
                    <span>-10 (Unpleasant)</span>
                    <span style="font-weight: 500;">0</span>
                    <span>+10 (Pleasant)</span>
                  </div>
                </div>

                <div>
                  <h4 style="margin-bottom: 18px; color: #333; font-size: 1.3em;">
                    <i class="fa fa-arrows-alt-v" style="color: #4e7ac7;"></i> Arousal
                  </h4>
                  <div style="display: flex; align-items: center; gap: 18px;">
                    <div class="value-bar" style="flex: 1; height: 30px; background: #f1f5f9; border-radius: 15px; position: relative; overflow: hidden; border: 2px solid #e2e8f0;">
                      <% arousal_percentage = ((@emotion_entry.arousal + 10) / 20.0) * 100 %>
                      <div style="width: <%= arousal_percentage %>%; height: 100%; background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 50%, #ef4444 100%); border-radius: 15px;"></div>
                    </div>
                    <span style="font-weight: 700; color: #4e7ac7; min-width: 50px; font-size: 1.4em;"><%= @emotion_entry.arousal %></span>
                  </div>
                  <div style="display: flex; justify-content: space-between; font-size: 0.9em; color: #666; margin-top: 12px; padding: 0 8px;">
                    <span>-10 (Calm)</span>
                    <span style="font-weight: 500;">0</span>
                    <span>+10 (Energetic)</span>
                  </div>
                </div>

                <!-- Current Position Summary -->
                <div style="margin-top: 40px; padding: 20px; background: #f8f9ff; border-radius: 12px; border: 2px solid #e2e8f0;">
                  <h5 style="margin: 0 0 10px 0; color: #4e7ac7; font-size: 1.1em;">
                    <i class="fa fa-map-marker"></i> Current Position
                  </h5>
                  <p style="margin: 0; color: #555; line-height: 1.5;">
                    <strong>Coordinates:</strong> (<%= @emotion_entry.valence %>, <%= @emotion_entry.arousal %>)<br>
                    <% if @emotion_entry.respond_to?(:predicted_emotion) && @emotion_entry.predicted_emotion.present? %>
                      <strong>Predicted Emotion:</strong> <%= @emotion_entry.predicted_emotion %>
                    <% end %>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Notes Section -->
        <div class="entry-notes" style="padding: 30px;">
          <h3 style="margin-bottom: 15px; color: #333;">
            <i class="fa fa-sticky-note"></i> Notes
          </h3>
          <% if @emotion_entry.notes.present? %>
            <div style="background: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid #4e7ac7;">
              <p style="margin: 0; line-height: 1.6; color: #333; white-space: pre-wrap;"><%= @emotion_entry.notes %></p>
            </div>
          <% else %>
            <div style="background: #f8f9fa; padding: 20px; border-radius: 8px; text-align: center;">
              <p style="margin: 0; color: #6b7280; font-style: italic;">
                <i class="fa fa-info-circle"></i> No notes recorded for this entry
              </p>
            </div>
          <% end %>
        </div>

        <!-- Metadata Section -->
        <div class="entry-metadata" style="padding: 20px 30px; background: #f8f9fa; border-top: 1px solid #edf2f7;">
          <div style="display: flex; justify-content: space-between; font-size: 0.9em; color: #6b7280;">
            <div>
              <i class="fa fa-calendar-plus"></i>
              Created: <%= @emotion_entry.created_at.strftime("%B %d, %Y at %I:%M %p") %>
            </div>
            <% if @emotion_entry.updated_at != @emotion_entry.created_at %>
              <div>
                <i class="fa fa-edit"></i>
                Last updated: <%= @emotion_entry.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
              </div>
            <% end %>
          </div>
        </div>

      </div>

      <!-- Related Actions -->
      <div style="margin-top: 30px; text-align: center;">
        <p style="color: #6b7280; margin-bottom: 20px;">Want to track more emotions?</p>
        <%= link_to new_emotion_entry_path, class: "button primary large", style: "padding: 12px 24px; border-radius: 8px; margin-right: 10px;" do %>
          <i class="fa fa-plus-circle"></i> Add New Emotion Entry
        <% end %>
        <%= link_to emotion_entries_path, class: "button large", style: "padding: 12px 24px; border-radius: 8px;" do %>
          <i class="fa fa-chart-line"></i> View All Entries
        <% end %>
      </div>

    </div>
  </div>
</section>