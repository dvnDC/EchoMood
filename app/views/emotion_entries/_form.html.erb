<%= form_with(model: emotion_entry, local: true, class: "emotion-form",
              data: { controller: "emotion-form" }) do |form| %>
  <% if emotion_entry.errors.any? %>
    <div class="error-messages">
      <h2><%= pluralize(emotion_entry.errors.count, "error") %> prevented this entry from being saved:</h2>
      <ul>
        <% emotion_entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :date, "Date" %>
    <%= form.date_field :date, required: true %>
  </div>

  <div class="form-group">
    <%= form.label :entry_time, "Time" %>
    <%= form.time_field :entry_time, required: true %>
  </div>

  <div class="emotion-slider-container">
    <h3>How are you feeling?</h3>

    <div id="emotion-visual-guide" class="emotion-quadrants">
      <div class="quadrant q1">Joy/Excitement</div>
      <div class="quadrant q2">Anger/Fear</div>
      <div class="quadrant q3">Sadness/Depression</div>
      <div class="quadrant q4">Peace/Relaxation</div>
      <div id="emotion-marker" class="marker" data-emotion-form-target="emotionMarker"></div>
    </div>

    <div class="emotion-sliders">
      <div class="slider-group">
        <%= form.label :valence, "Valence: From unpleasant to pleasant feelings" %>
        <div class="slider-labels">
          <span>Very unpleasant</span>
          <span>Neutral</span>
          <span>Very pleasant</span>
        </div>
        <%= form.range_field :valence, min: -10, max: 10, step: 1, class: "slider",
                             data: { emotion_form_target: "valenceSlider", action: "input->emotion-form#updateEmotionDisplay" } %>
        <div class="value-display">Value: <span data-emotion-form-target="valenceValue">0</span></div>
      </div>

      <div class="slider-group">
        <%= form.label :arousal, "Arousal: From calm to energetic feelings" %>
        <div class="slider-labels">
          <span>Very calm</span>
          <span>Moderate</span>
          <span>Very energetic</span>
        </div>
        <%= form.range_field :arousal, min: -10, max: 10, step: 1, class: "slider",
                             data: { emotion_form_target: "arousalSlider", action: "input->emotion-form#updateEmotionDisplay" } %>
        <div class="value-display">Value: <span data-emotion-form-target="arousalValue">0</span></div>
      </div>
    </div>

    <div class="emotion-prediction">
      <p>Based on the selected values, you are likely feeling:</p>
      <div class="emotion-name" data-emotion-form-target="predictedEmotion">Neutral</div>
    </div>
  </div>

  <div class="form-group">
    <%= form.label :notes, "Notes (optional)" %>
    <%= form.text_area :notes, rows: 4, placeholder: "Describe your feelings or what might have caused them..." %>
  </div>

  <div class="form-actions">
    <%= form.submit "Save", class: "button primary" %>
    <%= link_to "Return", emotion_entries_path, class: "button secondary" %>
  </div>
<% end %>
