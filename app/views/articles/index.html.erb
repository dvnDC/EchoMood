<div class="container">
  <h1>Artykuły i poradniki</h1>

  <div class="row">
    <% @articles.each do |article| %>
      <div class="col-md-4 mb-4">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title"><%= article[:title] %></h5>
            <p class="card-text">Dowiedz się więcej na temat tego zagadnienia...</p>
            <%= link_to "Czytaj więcej", article_path(article[:id]), class: "btn btn-primary" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
