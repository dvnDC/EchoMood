<!-- Header -->
<div id="header">

  <!-- Logo -->
  <div class="logo-container">
    <%= link_to root_path, id: 'logo' do %>
      <div class="logo-text">
        <span class="logo-echo">EchoMood</span>
        <div class="logo-tagline">Track your emotional journey</div>
      </div>
    <% end %>
  </div>

  <!-- Desktop Nav (original) -->
  <nav id="nav">
    <ul>
      <li class="<%= current_page?(home_index_path) ? 'current' : '' %>"><%= link_to 'Home', home_index_path %></li>
      <li class="<%= params[:controller] == 'articles' ? 'current' : '' %> opener">
        <a href="<%= articles_path %>">Articles</a>
        <ul>
          <li><%= link_to 'All Articles', articles_path %></li>
          <li><%= link_to 'Introduction', article_path('introduction') %></li>
          <li><%= link_to 'Methods', article_path('methods') %></li>
          <li><%= link_to 'Benefits', article_path('benefits') %></li>
          <li class="opener">
            <a href="#">Advanced</a>
            <ul>
              <li><%= link_to 'Movement is medicine', article_path('movement') %></li>
              <li><%= link_to 'Meditation', article_path('meditation') %></li>
              <li><%= link_to 'Analyzing Patterns', article_path('patterns') %></li>
              <li><%= link_to 'Emotional Intelligence', article_path('emotional-intelligence') %></li>
              <li><%= link_to 'Case Studies', article_path('case-studies') %></li>
              <li><%= link_to 'Scientific Research', article_path('research') %></li>
            </ul>
          </li>
          <li><%= link_to 'Resources', article_path('resources') %></li>
        </ul>
      </li>
      <li class="<%= current_page?(mood_entries_path) ? 'current' : '' %>"><%= link_to 'Mood Tracking', mood_entries_path %></li>
      <li class="<%= current_page?(emotion_entries_path) ? 'current' : '' %>"><%= link_to 'Emotion Map', emotion_entries_path %></li>
      <li class="<%= current_page?(meditation_path) ? 'current' : '' %>"><%= link_to 'Meditation', meditation_path %></li>
      <li class="spacer"></li>
      <li class="spacer"></li>
      <% if user_signed_in? %>
        <% if current_user.admin? %>
          <li><%= link_to "Admin", admin_users_path %></li>
        <% end %>
        <li><%= link_to "#{current_user.nickname}", "#" %></li>
        <li>
          <%= form_with url: destroy_user_session_path, method: :delete, local: true, style: "display: inline;" do %>
            <%= submit_tag "Logout", style: "background: none; border: none; color: rgba(255, 255, 255, 0.7); cursor: pointer; font-family: inherit; font-size: inherit; text-decoration: none; padding: 0; margin: 0; line-height: inherit; font-weight: inherit;" %>          <% end %>
        </li>
      <% else %>
        <li class="<%= current_page?(new_user_session_path) ? 'current' : '' %>"><%= link_to 'Sign in', new_user_session_path %></li>
        <li class="<%= current_page?(new_user_registration_path) ? 'current' : '' %>"><%= link_to 'Sign up', new_user_registration_path %></li>
      <% end %>
    </ul>
  </nav>

</div>

<!-- Mobile Menu Button -->
<button class="mobile-btn" onclick="document.getElementById('mobileMenu').classList.add('show')">
  <span></span>
</button>

<!-- Mobile Menu -->
<div id="mobileMenu" class="mobile-menu">
  <button class="close-btn" onclick="document.getElementById('mobileMenu').classList.remove('show')">
    ✕
  </button>

  <div class="mobile-menu-header">
    <h2>EchoMood</h2>
    <p>Track your emotional journey</p>
  </div>

  <ul>
    <li><%= link_to home_index_path, onclick: "document.getElementById('mobileMenu').classList.remove('show')" do %>Home<% end %></li>
    <li><%= link_to articles_path, onclick: "document.getElementById('mobileMenu').classList.remove('show')" do %>Articles<% end %></li>
    <li><%= link_to mood_entries_path, onclick: "document.getElementById('mobileMenu').classList.remove('show')" do %>Mood Tracking<% end %></li>
    <li><%= link_to emotion_entries_path, onclick: "document.getElementById('mobileMenu').classList.remove('show')" do %>Emotion Map<% end %></li>
    <li><%= link_to meditation_path, onclick: "document.getElementById('mobileMenu').classList.remove('show')" do %>Meditation<% end %></li>

    <div class="user-section">
      <% if user_signed_in? %>
        <% if current_user.admin? %>
          <li><%= link_to admin_users_path, onclick: "document.getElementById('mobileMenu').classList.remove('show')" do %>Admin Panel<% end %></li>
        <% end %>
        <li><%= link_to edit_user_registration_path, onclick: "document.getElementById('mobileMenu').classList.remove('show')" do %>Profile (<%= current_user.nickname %>)<% end %></li>
        <li>
          <%= form_with url: destroy_user_session_path, method: :delete, local: true, style: "display: block; margin: 0;" do %>
            <%= submit_tag "Logout",
                           style: "display: flex; align-items: center; padding: 18px 25px; background: rgba(231, 76, 60, 0.8); color: white; text-decoration: none; border-radius: 12px; font-size: 16px; font-weight: 500; transition: all 0.3s ease; backdrop-filter: blur(5px); border: 1px solid rgba(255, 255, 255, 0.1); width: 100%; cursor: pointer; font-family: inherit;",
                           onclick: "document.getElementById('mobileMenu').classList.remove('show')" %>
          <% end %>
        </li>
      <% else %>
        <li><%= link_to new_user_session_path, onclick: "document.getElementById('mobileMenu').classList.remove('show')", class: "auth-btn" do %>Sign In<% end %></li>
        <li><%= link_to new_user_registration_path, onclick: "document.getElementById('mobileMenu').classList.remove('show')", class: "auth-btn" do %>Sign Up<% end %></li>
      <% end %>
    </div>
  </ul>
</div>